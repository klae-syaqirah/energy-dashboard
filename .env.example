# --- Web app (copy to .env.local for `npm run dev`; set the same on Vercel) ---

# Neon Postgres connection string (Neon console -> your project -> Connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Shared secret the Python bridge must send. Make it long and random.
INGEST_API_KEY=change-me-to-a-long-random-string

# Optional: TNB tariff used for the "Est. Cost Today" card (RM per kWh)
TARIFF_RM_PER_KWH=0.365

# --- Python bridge (copy these two into bridge/.env on the laptop) ---
# PQM_API_URL=https://your-app.vercel.app
# PQM_API_KEY=same-value-as-INGEST_API_KEY
